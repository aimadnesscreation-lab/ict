# ═══════════════════════════════════════════════════════════════════════
#  ICT Trading Intelligence Platform — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required: BINANCE_API_KEY + BINANCE_SECRET (without these, exchange
#           execution is disabled and sync workers won't start).
#
# ──────────────────────────────────────────────────────────────────────


# ═══════════════════════════════════════════════════════════════════════
#  BINANCE API CREDENTIALS (Required)
# ═══════════════════════════════════════════════════════════════════════
#
# Generate at: https://www.binance.com/en/support/faq/how-to-create-api-keys-on-binance-360002502072
#
# Futures-specific API keys are needed for USDⓈ-M Futures trading.
# For demo/testnet: use keys from https://testnet.binancefuture.com/
# For live: use main Binance API keys with Futures permissions enabled.
#
# WARNING: Never share these values or commit them to version control.

BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here


# ═══════════════════════════════════════════════════════════════════════
#  EXCHANGE MODE (Optional — Default: demo)
# ═══════════════════════════════════════════════════════════════════════
#
# Controls whether the LiveExecutor connects to Binance Futures Testnet
# or the real Binance Futures production exchange.
#
# Valid values:
#   demo  — Binance Futures Testnet (paper trading, no real funds)
#   live  — Binance Futures LIVE (⚠️ real funds at risk!)
#
# In demo mode, the executor calls enable_demo_trading(True) on the CCXT
# exchange instance, which routes orders to testnet.binancefuture.com.

EXCHANGE_MODE=demo


# ═══════════════════════════════════════════════════════════════════════
#  DEMO ACCOUNT INITIAL BALANCE (Optional — Default: 5000)
# ═══════════════════════════════════════════════════════════════════════
#
# Starting capital for the DemoAccount forward-testing engine.
# Used as the base for position sizing (1% risk per trade).
#
# This is virtual balance — it only affects DemoAccount state in memory
# and in the SQLite database (trading.db). It has no effect on real
# exchange balances.

DEMO_INITIAL_BALANCE=5000


# ═══════════════════════════════════════════════════════════════════════
#  DISCORD WEBHOOK URL (Optional)
# ═══════════════════════════════════════════════════════════════════════
#
# Discord channel webhook URL for trade notifications. When set, the
# system sends an embedded message to Discord every time a new position
# is opened (including signal type, score, price, confluences, etc.).
#
# Create a webhook: Server Settings → Integrations → Webhooks → New
#
# Leave empty to disable Discord notifications.

# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token


# ═══════════════════════════════════════════════════════════════════════
#  DASHBOARD — API URL (Optional — Development Only)
# ═══════════════════════════════════════════════════════════════════════
#
# Used by the Vite dev server to proxy API requests to the backend.
# In production (static build in api/static/), the dashboard is served
# by FastAPI on the same origin, so this is not needed.
#
# Default (when unset): same origin as the dashboard (works in production)
# Development: http://localhost:8000 (when using Vite dev server)

# VITE_API_URL=http://localhost:8000


# ═══════════════════════════════════════════════════════════════════════
#  DASHBOARD — WEBSOCKET URL (Optional — Override Only)
# ═══════════════════════════════════════════════════════════════════════
#
# Explicit WebSocket URL override for the dashboard's real-time data
# stream. When unset, the WebSocket URL is derived automatically:
#   - From VITE_API_URL (if set) by changing http→ws / https→wss
#   - Otherwise from window.location (same origin)
#
# This should rarely need to be set explicitly — only if the WebSocket
# endpoint lives on a different host than the API.

# VITE_WS_URL=ws://localhost:8000/ws/data
