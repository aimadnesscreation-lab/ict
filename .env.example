# Exchange Configuration
# Options: 'okx' or 'binance'
EXCHANGE_NAME=binance
# Mode: 'live' or 'demo' (Binance Testnet / OKX Demo)
EXCHANGE_MODE=demo

# Binance API Credentials (Only if using Binance)
BINANCE_API_KEY=your_binance_testnet_key
BINANCE_SECRET=your_binance_testnet_secret

# OKX API Credentials (Only if using OKX)
OKX_API_KEY=your_api_key_here
OKX_SECRET=your_secret_here
OKX_PASSPHRASE=your_passphrase_here

# Risk Settings
DEFAULT_RISK_PCT=1.0
MAX_OPEN_POSITIONS=3
