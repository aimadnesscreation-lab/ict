# ────────────────────────────────────────────────────────────
# Binance Trading Pipeline — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ────────────────────────────────────────────────────────────

# ── Exchange Credentials ────────────────────────────────────
# Binance API keys (required for live/demo execution).
# Use Binance Demo Trading Portal credentials for testing.
BINANCE_API_KEY=
BINANCE_SECRET=

# OKX API keys (optional — only needed if you switch EXCHANGE_NAME to "okx").
# Public data (OHLCV candles) does not require API keys.
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=

# ── Exchange Mode ───────────────────────────────────────────
# Which exchange to trade on: "binance" or "okx" (default: binance)
EXCHANGE_NAME=binance

# Execution mode: "demo" for paper trading, "live" for real money (default: demo)
EXCHANGE_MODE=demo

# ── Trading Configuration ──────────────────────────────────
# Futures leverage (default: 10). Set to 5 or 10 for safe paper trading.
LEVERAGE=10

# Demo account starting balance in USDT (default: 5000).
# Must match or be less than your actual exchange demo balance.
DEMO_INITIAL_BALANCE=5000

# ── Discord Alerts ──────────────────────────────────────────
# Webhook URL for trade signal notifications (optional).
# Leave empty to disable Discord integration.
DISCORD_WEBHOOK_URL=

# ── Deployment ──────────────────────────────────────────────
# Render deployment only — not used in local development.
# Set by Render automatically; leave commented out for local use.
# PORT=10000
# VITE_API_URL=https://ict-trading-api.onrender.com
