//@version=5
strategy("ICT Dual-Score Strategy", overlay=true, initial_capital=10000,
  default_qty_type=strategy.percent_of_equity, default_qty_value=100,
  commission_type=strategy.commission.percent, commission_value=0.04,
  pyramiding=1, currency=currency.USD)

// ─── User Inputs ──────────────────────────────────────────────────────────

// Signal Weights
wtBias    = input.int(20, "HTF Bias Weight",     group="Weights", minval=0, maxval=40)
wtMSS     = input.int(20, "MSS Weight",          group="Weights", minval=0, maxval=40)
wtSweep   = input.int(20, "Liquidity Sweep Weight", group="Weights", minval=0, maxval=40)
wtFVG     = input.int(15, "FVG Weight",          group="Weights", minval=0, maxval=30)
wtOB      = input.int(15, "Order Block Weight",   group="Weights", minval=0, maxval=30)
wtDiscount= input.int(10, "Discount Zone Weight", group="Weights", minval=0, maxval=20)
wtOTE     = input.int(10, "OTE Zone Weight",     group="Weights", minval=0, maxval=20)
wtSession = input.int(10, "Session/Kill Zone Weight", group="Weights", minval=0, maxval=20)

// Risk Management
slMultiplier    = input.float(1.5, "ATR x SL Multiplier", group="Risk", step=0.1)
rrTarget        = input.float(2.0, "Risk:Reward Target",   group="Risk", step=0.1, minval=0.5)
riskPerTradePct = input.float(1.0, "Risk Per Trade (%)",   group="Risk", step=0.1)

// Technical Parameters
pivotLookback  = input.int(3,  "Pivot Lookback",   group="Tech", minval=1, maxval=10)
fvgLookback    = input.int(5,  "FVG Lookback Bars", group="Tech", minval=1, maxval=20)
atrLength      = input.int(14, "ATR Period",        group="Tech", minval=5, maxval=50)
obAtrMult      = input.float(2.0, "OB Impulse Mult", group="Tech", step=0.1)
emaFast        = input.int(12, "EMA Fast",   group="Tech", minval=1)
emaSlow        = input.int(26, "EMA Slow",   group="Tech", minval=1)
emaThreshold   = input.float(0.5, "EMA Threshold %", group="Tech", step=0.1)

// Session Filters
useKillZoneOnly   = input.bool(true, "Only Trade in Kill Zones", group="Sessions")

// Display
showFVG         = input.bool(true,  "Show FVG Zones",    group="Display")
showOB          = input.bool(true,  "Show Order Blocks", group="Display")
showSwingPoints = input.bool(true,  "Show Swing Points", group="Display")
showSignals     = input.bool(true,  "Show Signal Labels", group="Display")
showScoreTable  = input.bool(true,  "Show Score Table",  group="Display")
minScoreToTrade = input.int(70,     "Min Score to Trade", group="Display", minval=0, maxval=100)

// ─── Session & Kill Zone Detection ────────────────────────────────────────

isAsianSession(h)  => h >= 0  and h < 9
isLondonSession(h) => h >= 8 and h < 17
isNewYorkSession(h)=> h >= 13 and h < 22
isLondonKillZone(h)=> h >= 7  and h < 9
isNewYorkKillZone(h)=> h >= 13 and h < 15

hourUTC = hour(time)
inAsian  = isAsianSession(hourUTC)
inLondon = isLondonSession(hourUTC)
inNY     = isNewYorkSession(hourUTC)
inLKZ    = isLondonKillZone(hourUTC)
inNYKZ   = isNewYorkKillZone(hourUTC)
inKillZone   = inLKZ or inNYKZ
activeSessionCount = (inAsian ? 1 : 0) + (inLondon ? 1 : 0) + (inNY ? 1 : 0)
sessionBonus = inKillZone ? 10 : activeSessionCount >= 2 ? 5 : 0

// ─── Technical Indicators ─────────────────────────────────────────────────

atrVal = ta.atr(atrLength)
emaFastVal = ta.ema(close, emaFast)
emaSlowVal = ta.ema(close, emaSlow)

// HTF Bias (1h, non-repainting)
htfClose = request.security(syminfo.tickerid, "60", close[1],
  lookahead=barmerge.lookahead_on)
htfEmaFast = ta.ema(htfClose, emaFast)
htfEmaSlow = ta.ema(htfClose, emaSlow)
htfDiffPct = ((htfEmaFast - htfEmaSlow) / htfClose) * 100
htfBias = htfDiffPct >  emaThreshold ? "bullish" :
  htfDiffPct < -emaThreshold ? "bearish" : "neutral"

// ─── ICT Pattern Detection ────────────────────────────────────────────────

// Swings
swingHigh = ta.pivothigh(high, pivotLookback, pivotLookback)
swingLow  = ta.pivotlow(low, pivotLookback, pivotLookback)

var lastSwingHigh = na
var lastSwingLow  = na
if not na(swingHigh)
  lastSwingHigh := swingHigh
if not na(swingLow)
  lastSwingLow  := swingLow

// MSS
isBullishMSS = not na(lastSwingHigh) and close > lastSwingHigh[2]
isBearishMSS = not na(lastSwingLow)  and close < lastSwingLow[2]
mssType = isBullishMSS ? "BULLISH_MSS" : isBearishMSS ? "BEARISH_MSS" : na

// FVG
bullishFVG = high[2] < low
bearishFVG = low[2]  > high
fvgDetectedBullish = ta.cum(bullishFVG) > ta.cum(bullishFVG)[fvgLookback]
fvgDetectedBearish = ta.cum(bearishFVG) > ta.cum(bearishFVG)[fvgLookback]

// Order Blocks
futureMoveSize = abs(close[3] - close)
impulseMove = futureMoveSize > (atrVal * obAtrMult)
isBullishImpulse = (close[3] > close) and impulseMove
isBearishImpulse = (close[3] < close) and impulseMove
isBearishCandle = close[1] < open[1]
isBullishCandle = close[1] > open[1]
bullishOB = isBullishImpulse and isBearishCandle[1]
bearishOB = isBearishImpulse  and isBullishCandle[1]
obDetectedBullish = ta.cum(bullishOB) > ta.cum(bullishOB)[fvgLookback]
obDetectedBearish = ta.cum(bearishOB) > ta.cum(bearishOB)[fvgLookback]

// Liquidity Sweeps
brokeBelowSwingLow  = not na(lastSwingLow)  and low   < lastSwingLow[1]
reclaimedSwingLow   = not na(lastSwingLow)  and close > lastSwingLow[1]
bullishSweep = brokeBelowSwingLow and reclaimedSwingLow
brokeAboveSwingHigh = not na(lastSwingHigh) and high  > lastSwingHigh[1]
reclaimedSwingHigh  = not na(lastSwingHigh) and close < lastSwingHigh[1]
bearishSweep = brokeAboveSwingHigh and reclaimedSwingHigh
sweepType = bullishSweep ? "BULLISH" : bearishSweep ? "BEARISH" : na

// Premium/Discount + OTE
dealingHigh = na(lastSwingHigh) ? ta.highest(high, 20) : lastSwingHigh
dealingLow  = na(lastSwingLow)  ? ta.lowest(low, 20)   : lastSwingLow
dealingRange = dealingHigh - dealingLow
equilibriumVal  = (dealingHigh + dealingLow) / 2
ote62 = dealingLow + dealingRange * 0.62
ote79 = dealingLow + dealingRange * 0.79
inDiscount = close < equilibriumVal
inOTE = close >= ote62 and close <= ote79

// ─── Dual-Score Signal Engine ─────────────────────────────────────────────

bullishScore = 0
bearishScore = 0

// 1. Bias / HTF Alignment
if htfBias == "bullish"
  bullishScore += wtBias
else if htfBias == "bearish"
  bearishScore += wtBias

// 2. MSS
if mssType == "BULLISH_MSS"
  bullishScore += wtMSS
else if mssType == "BEARISH_MSS"
  bearishScore += wtMSS

// 3. Liquidity Sweep
if sweepType == "BULLISH"
  bullishScore += wtSweep
else if sweepType == "BEARISH"
  bearishScore += wtSweep

// 4. FVG
if fvgDetectedBullish
  bullishScore += wtFVG
if fvgDetectedBearish
  bearishScore += wtFVG

// 5. Order Block
if obDetectedBullish
  bullishScore += wtOB
if obDetectedBearish
  bearishScore += wtOB

// 6. Premium / Discount Zone
if htfBias == "bullish" and inDiscount
  bullishScore += wtDiscount
else if htfBias == "bearish" and not inDiscount
  bearishScore += wtDiscount
else
  if inDiscount
    bullishScore += wtDiscount / 2
  else
    bearishScore += wtDiscount / 2

// 7. OTE
if inOTE
  if htfBias == "bullish"
    bullishScore += wtOTE
  else if htfBias == "bearish"
    bearishScore += wtOTE
  else
    bullishScore += wtOTE / 2
    bearishScore += wtOTE / 2

// 8. Session / Kill Zone
if htfBias == "bullish"
  bullishScore += sessionBonus
else if htfBias == "bearish"
  bearishScore += sessionBonus
else
  bullishScore += sessionBonus / 2
  bearishScore += sessionBonus / 2

// Cap scores
bullishScore := math.min(bullishScore, 100)
bearishScore := math.min(bearishScore, 100)

netScore = bullishScore - bearishScore
confidenceStrength = math.max(bullishScore, bearishScore)
signalType = netScore >= 60 ? "STRONG_BUY" :
  netScore >= 30 ? "BUY" :
  netScore > -30 ? "NEUTRAL" :
  netScore > -60 ? "SELL" : "STRONG_SELL"

// HTF alignment check
htfAligned = true
if htfBias != "neutral"
  if htfBias == "bullish" and (signalType == "SELL" or signalType == "STRONG_SELL")
    htfAligned := false
  else if htfBias == "bearish" and (signalType == "BUY" or signalType == "STRONG_BUY")
    htfAligned := false

// Entry conditions
isBuySignal  = (signalType == "STRONG_BUY" or signalType == "BUY")
  and confidenceStrength >= minScoreToTrade
isSellSignal = (signalType == "STRONG_SELL" or signalType == "SELL")
  and confidenceStrength >= minScoreToTrade
kzFilter     = useKillZoneOnly ? inKillZone : true
htfFilter    = htfAligned or (htfBias == "neutral")
entryConditionLong  = isBuySignal  and kzFilter and htfFilter
entryConditionShort = isSellSignal and kzFilter and htfFilter

// ─── Position Sizing ──────────────────────────────────────────────────────

calcQty() => strategy.equity * riskPerTradePct / 100.0 / (atrVal * slMultiplier)

// ─── Trade Execution ──────────────────────────────────────────────────────

if barstate.isconfirmed
  if entryConditionLong and strategy.position_size <= 0
    stopDist2 = atrVal * slMultiplier
    qty = calcQty()
    strategy.entry("Long", strategy.long, qty=qty)
    strategy.exit("Long Exit", "Long",
      stop=close - stopDist2, limit=close + (stopDist2 * rrTarget))

  if entryConditionShort and strategy.position_size >= 0
    stopDist2 = atrVal * slMultiplier
    qty = calcQty()
    strategy.entry("Short", strategy.short, qty=qty)
    strategy.exit("Short Exit", "Short",
      stop=close + stopDist2, limit=close - (stopDist2 * rrTarget))

// ─── Visual Plotting ──────────────────────────────────────────────────────

plotshape(showSwingPoints ? swingHigh : na, "Swing High",
  style=shape.triangledown, location=location.abovebar,
  color=color.new(#f43f5e, 40), size=size.tiny)
plotshape(showSwingPoints ? swingLow  : na, "Swing Low",
  style=shape.triangleup, location=location.belowbar,
  color=color.new(#22c55e, 40), size=size.tiny)

plot(emaFastVal, "EMA Fast", color=color.new(#06b6d4, 60), linewidth=1)
plot(emaSlowVal, "EMA Slow", color=color.new(#f59e0b, 60), linewidth=1)

oteP1 = plot(ote62, "OTE 62%", display=display.none)
oteP2 = plot(ote79, "OTE 79%", display=display.none)
fill(oteP1, oteP2, color=color.new(#8b5cf6, 85), title="OTE Zone")

plot(equilibriumVal, "Equilibrium",
  color=color.new(#64748b, 50), linewidth=1, style=plot.style_dashed)

bgcolor(showFVG and bullishFVG ? color.new(#22c55e, 85) : na, title="Bullish FVG")
bgcolor(showFVG and bearishFVG  ? color.new(#f43f5e, 85) : na, title="Bearish FVG")
bgcolor(showOB  and bullishOB  ? color.new(#06b6d4, 80) : na, title="Bullish OB")
bgcolor(showOB  and bearishOB   ? color.new(#f59e0b, 80) : na, title="Bearish OB")

if showSignals and entryConditionLong
  label.new(bar_index, low, "B " + str.tostring(confidenceStrength),
    style=label.style_label_up, color=color.new(#22c55e, 70),
    textcolor=color.white, size=size.small)

if showSignals and entryConditionShort
  label.new(bar_index, high, "S " + str.tostring(confidenceStrength),
    style=label.style_label_down, color=color.new(#f43f5e, 70),
    textcolor=color.white, size=size.small)

// Kill zone background
bgcolor(showSignals and inKillZone ? color.new(#8b5cf6, 90) : na, title="Kill Zone")

// ─── Score Table ──────────────────────────────────────────────────────────

// Table row helper
rowCell(tbl, y, lbl, pts, active, activeClr) =>
  c = active ? activeClr : color.gray
  k = active ? "+" + str.tostring(pts) : "0"
  table.cell(tbl, 0, y, lbl, text_color=c, text_size=size.tiny, text_halign=text.align_left)
  table.cell(tbl, 1, y, k, text_color=c, text_size=size.tiny, text_halign=text.align_right)
  
var table tbl = table.new(position.top_right, 2, 15,
  bgcolor=color.new(#0f172a, 85), border_width=1,
  border_color=color.new(#334155, 70))

if showScoreTable and barstate.islast
  table.cell(tbl, 0, 0, "ICT Score Engine",
    text_color=color.white, text_size=size.small, text_halign=text.align_center)
  table.cell(tbl, 1, 0, "Score",
    text_color=color.white, text_size=size.small)

  biasActive = htfBias == "bullish" or htfBias == "bearish"
  mssActive  = mssType == "BULLISH_MSS" or mssType == "BEARISH_MSS"
  swpActive  = sweepType == "BULLISH" or sweepType == "BEARISH"
  fvgActive  = fvgDetectedBullish or fvgDetectedBearish
  obActive   = obDetectedBullish or obDetectedBearish
  discActive = (htfBias == "bullish" and inDiscount)
    or (htfBias == "bearish" and not inDiscount)
  oteActive  = inOTE
  kzActive   = inKillZone

  rowCell(tbl, 1,  "Bias",     wtBias,     biasActive, color.green)
  rowCell(tbl, 2,  "MSS",      wtMSS,      mssActive,  color.cyan)
  rowCell(tbl, 3,  "Sweep",    wtSweep,    swpActive,  color.orange)
  rowCell(tbl, 4,  "FVG",      wtFVG,      fvgActive,  color.purple)
  rowCell(tbl, 5,  "OB",       wtOB,       obActive,   color.red)
  rowCell(tbl, 6,  "DiscZone", wtDiscount, discActive,
    htfBias == "bullish" ? color.green : color.red)
  rowCell(tbl, 7,  "OTE",      wtOTE,      oteActive,  color.yellow)
  rowCell(tbl, 8,  "Session",  wtSession,  kzActive,   color.green)

  // Net score
  netC = netScore >= 30 ? color.green :
    netScore <= -30 ? color.red : color.gray
  table.cell(tbl, 0, 9, "NET",
    text_color=color.new(#64748b, 90), text_size=size.tiny)
  table.cell(tbl, 1, 9, str.tostring(netScore),
    text_color=netC, text_size=size.small, text_halign=text.align_right)

  // Signal type
  sigC = signalType == "STRONG_BUY" or signalType == "BUY" ? color.green :
    signalType == "STRONG_SELL" or signalType == "SELL" ? color.red : color.gray
  table.cell(tbl, 0, 10, signalType,
    text_color=sigC, text_size=size.small, text_halign=text.align_center)
  table.cell(tbl, 1, 10, "(" + str.tostring(confidenceStrength) + ")",
    text_color=sigC, text_size=size.tiny)

  // HTF Bias
  htfC = htfBias == "bullish" ? color.green :
    htfBias == "bearish" ? color.red : color.gray
  table.cell(tbl, 0, 11, "HTF Bias",
    text_color=color.new(#64748b, 90), text_size=size.tiny)
  table.cell(tbl, 1, 11, str.upper(htfBias),
    text_color=htfC, text_size=size.tiny, text_halign=text.align_right)

  // Kill Zone
  table.cell(tbl, 0, 12, "Kill Zone",
    text_color=color.new(#64748b, 90), text_size=size.tiny)
  table.cell(tbl, 1, 12, inKillZone ? "ACTIVE" : "INACTIVE",
    text_color=kzActive ? color.green : color.gray,
    text_size=size.tiny, text_halign=text.align_right)

// ─── Alerts ───────────────────────────────────────────────────────────────

alertcondition(entryConditionLong, "ICT Buy Signal",
  "BUY {{ticker}} Score: {{close}}")
alertcondition(entryConditionShort, "ICT Sell Signal",
  "SELL {{ticker}} Score: {{close}}")
